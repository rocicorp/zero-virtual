{
  "name": "@rocicorp/zero-virtual",
  "version": "0.4.1",
  "description": "Infinite Virtual Scroller for Zero",
  "keywords": [
    "infinite",
    "scroller",
    "virtual",
    "zero"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/rocicorp/zero-virtual"
  },
  "files": [
    "dist/",
    "src/**/*.ts",
    "!*.tsbuildinfo"
  ],
  "type": "module",
  "main": "index.js",
  "exports": {
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    }
  },
  "scripts": {
    "dev": "pnpm --filter demo dev",
    "check-types": "tsgo -p src/tsconfig.json && tsgo -p demo/tsconfig.app.json && tsgo -p demo/tsconfig.node.json",
    "lint": "oxlint --type-aware",
    "format": "oxfmt",
    "build": "tsgo -p src/tsconfig.json",
    "prepack": "rm -rf dist && pnpm run build"
  },
  "devDependencies": {
    "@rocicorp/zero": "^0.25.13",
    "@tanstack/react-virtual": "^3.13.21",
    "@tanstack/virtual-core": "^3.13.21",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260311.1",
    "oxfmt": "^0.38.0",
    "oxlint": "^1.53.0",
    "oxlint-tsgolint": "^0.16.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vite": "^7.3.1"
  },
  "peerDependencies": {
    "@rocicorp/zero": ">=0.25.0 <2.0.0",
    "@tanstack/react-virtual": "^3.13.0",
    "@tanstack/virtual-core": "^3.13.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "packageManager": "pnpm@10.30.2"
}
